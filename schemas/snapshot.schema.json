{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "eToro Portfolio Snapshot Schema",
  "description": "A stable minimal schema for portfolio positions and cash reserves.",
  "type": "object",
  "properties": {
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "currency": {
      "type": "string"
    },
    "cash_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "total_value_usd": {
      "type": "number",
      "description": "Total portfolio value in USD (invested equity + cash). Optional — present when eToro API provides absolute amounts."
    },
    "positions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ticker": {
            "type": "string"
          },
          "asset_type": {
            "type": "string"
          },
          "region": {
            "type": "string"
          },
          "sector": {
            "type": "string"
          },
          "weight_pct": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "price": {
            "type": "number"
          },
          "avg_open": {
            "type": "number"
          },
          "pnl_pct": {
            "type": "number"
          },
          "market_value_usd": {
            "type": "number",
            "description": "Current market value of this position in USD. Optional — present when eToro API provides absolute amounts."
          },
          "units": {
            "type": "number",
            "description": "Number of units/shares held. Optional — present when available from API."
          }
        },
        "required": [
          "ticker",
          "asset_type",
          "region",
          "sector",
          "weight_pct"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "date",
    "currency",
    "cash_pct",
    "positions"
  ],
  "additionalProperties": false
}