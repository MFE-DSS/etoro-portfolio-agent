{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "eToro Macro-Regime State Schema",
    "description": "Output schema for the V5 Macro-Regime Econometrics layer.",
    "type": "object",
    "properties": {
        "timestamp_utc": {
            "type": "string",
            "format": "date-time"
        },
        "asof_date": {
            "type": "string",
            "format": "date"
        },
        "data_coverage": {
            "type": "object",
            "additionalProperties": {
                "type": "object",
                "properties": {
                    "start_date": {
                        "type": "string"
                    },
                    "end_date": {
                        "type": "string"
                    },
                    "missing_days": {
                        "type": "integer"
                    }
                },
                "required": [
                    "start_date",
                    "end_date",
                    "missing_days"
                ],
                "additionalProperties": false
            }
        },
        "features_summary": {
            "type": "object",
            "properties": {
                "total_features": {
                    "type": "integer"
                },
                "transforms_applied": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "lags_applied": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "required": [
                "total_features",
                "transforms_applied",
                "lags_applied"
            ],
            "additionalProperties": false
        },
        "model_markov": {
            "type": "object",
            "properties": {
                "p_bull": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "p_bear": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "bull_idx": {
                    "type": "integer"
                },
                "bear_idx": {
                    "type": "integer"
                },
                "regime_most_likely_idx": {
                    "type": "integer"
                },
                "most_likely_is_bull": {
                    "type": "boolean"
                },
                "diagnostics": {
                    "type": "object",
                    "properties": {
                        "loglik": {
                            "type": "number"
                        },
                        "aic": {
                            "type": "number"
                        },
                        "bic": {
                            "type": "number"
                        }
                    },
                    "additionalProperties": false
                },
                "params": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "number"
                    }
                },
                "regime_stats": {
                    "type": "object",
                    "properties": {
                        "means": {
                            "type": "array",
                            "items": {
                                "type": "number"
                            }
                        },
                        "variances": {
                            "type": "array",
                            "items": {
                                "type": "number"
                            }
                        },
                        "mean_variance_switching": {
                            "type": "boolean"
                        },
                        "switching_variance": {
                            "type": "boolean"
                        }
                    },
                    "additionalProperties": false
                }
            },
            "required": [
                "p_bull",
                "p_bear",
                "bull_idx",
                "bear_idx",
                "regime_most_likely_idx",
                "most_likely_is_bull",
                "diagnostics",
                "params",
                "regime_stats"
            ],
            "additionalProperties": false
        },
        "model_events": {
            "type": "object",
            "properties": {
                "p_drawdown_10": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "p_drawdown_20": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "p_drawdown_composite": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "horizon_days": {
                    "type": "integer",
                    "minimum": 1
                },
                "p_recession": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "dd20_positive_rate_train": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "coefficients": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "number"
                    }
                },
                "regularization_C": {
                    "type": "number"
                }
            },
            "required": [
                "p_drawdown_10",
                "p_drawdown_20",
                "p_drawdown_composite",
                "dd20_positive_rate_train",
                "horizon_days"
            ],
            "additionalProperties": false
        },
        "aggregate": {
            "type": "object",
            "properties": {
                "macro_score_0_100": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 100
                },
                "regime_state": {
                    "type": "string",
                    "enum": [
                        "RISK_ON",
                        "NEUTRAL",
                        "RISK_OFF"
                    ]
                },
                "traffic_light": {
                    "type": "string",
                    "enum": [
                        "GREEN",
                        "ORANGE",
                        "RED"
                    ]
                },
                "buy_the_dip_ok": {
                    "type": "boolean"
                },
                "recommended_action": {
                    "type": "string"
                }
            },
            "required": [
                "macro_score_0_100",
                "regime_state",
                "traffic_light",
                "buy_the_dip_ok",
                "recommended_action"
            ],
            "additionalProperties": false
        },
        "sanity_checks": {
            "type": "object",
            "properties": {
                "markov_probs_sum": {
                    "type": "number"
                },
                "markov_is_degenerate": {
                    "type": "boolean"
                },
                "events_is_degenerate": {
                    "type": "boolean"
                },
                "dd20_positive_rate_train": {
                    "type": "number"
                },
                "missing_key_features_count": {
                    "type": "integer",
                    "minimum": 0
                }
            },
            "required": [
                "markov_probs_sum",
                "markov_is_degenerate",
                "events_is_degenerate",
                "dd20_positive_rate_train",
                "missing_key_features_count"
            ],
            "additionalProperties": false
        },
        "flags": {
            "type": "array",
            "items": {
                "type": "string"
            }
        }
    },
    "required": [
        "timestamp_utc",
        "asof_date",
        "data_coverage",
        "features_summary",
        "model_markov",
        "model_events",
        "aggregate",
        "sanity_checks",
        "flags"
    ],
    "additionalProperties": false
}