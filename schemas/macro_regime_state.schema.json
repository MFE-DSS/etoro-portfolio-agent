{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "eToro Macro-Regime State Schema",
    "description": "Output schema for the V5 Macro-Regime Econometrics layer.",
    "type": "object",
    "properties": {
        "timestamp_utc": {
            "type": "string",
            "format": "date-time"
        },
        "asof_date": {
            "type": "string",
            "format": "date"
        },
        "data_coverage": {
            "type": "object",
            "additionalProperties": {
                "type": "object",
                "properties": {
                    "start_date": {
                        "type": "string"
                    },
                    "end_date": {
                        "type": "string"
                    },
                    "missing_days": {
                        "type": "integer"
                    }
                },
                "required": [
                    "start_date",
                    "end_date",
                    "missing_days"
                ],
                "additionalProperties": false
            }
        },
        "features_summary": {
            "type": "object",
            "properties": {
                "total_features": {
                    "type": "integer"
                },
                "transforms_applied": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "lags_applied": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "required": [
                "total_features",
                "transforms_applied",
                "lags_applied"
            ],
            "additionalProperties": false
        },
        "model_markov": {
            "type": "object",
            "properties": {
                "p_bull": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "p_bear": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "regime_label": {
                    "type": "integer",
                    "enum": [
                        0,
                        1
                    ]
                },
                "diagnostics": {
                    "type": "object",
                    "properties": {
                        "loglik": {
                            "type": "number"
                        },
                        "aic": {
                            "type": "number"
                        },
                        "bic": {
                            "type": "number"
                        }
                    },
                    "additionalProperties": false
                },
                "params": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "number"
                    }
                }
            },
            "required": [
                "p_bull",
                "p_bear",
                "regime_label",
                "diagnostics",
                "params"
            ],
            "additionalProperties": false
        },
        "model_events": {
            "type": "object",
            "properties": {
                "p_drawdown_20": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "horizon_days": {
                    "type": "integer",
                    "minimum": 1
                },
                "p_recession": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "coefficients": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "number"
                    }
                },
                "regularization_C": {
                    "type": "number"
                }
            },
            "required": [
                "p_drawdown_20",
                "horizon_days"
            ],
            "additionalProperties": false
        },
        "aggregate": {
            "type": "object",
            "properties": {
                "macro_score_0_100": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 100
                },
                "regime_state": {
                    "type": "string",
                    "enum": [
                        "RISK_ON",
                        "NEUTRAL",
                        "RISK_OFF"
                    ]
                },
                "traffic_light": {
                    "type": "string",
                    "enum": [
                        "GREEN",
                        "ORANGE",
                        "RED"
                    ]
                },
                "buy_the_dip_ok": {
                    "type": "boolean"
                },
                "recommended_action": {
                    "type": "string"
                }
            },
            "required": [
                "macro_score_0_100",
                "regime_state",
                "traffic_light",
                "buy_the_dip_ok",
                "recommended_action"
            ],
            "additionalProperties": false
        },
        "flags": {
            "type": "array",
            "items": {
                "type": "string"
            }
        }
    },
    "required": [
        "timestamp_utc",
        "asof_date",
        "data_coverage",
        "features_summary",
        "model_markov",
        "model_events",
        "aggregate",
        "flags"
    ],
    "additionalProperties": false
}